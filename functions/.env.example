# Firebase Functions Environment Variables
# Copy this file to .env and fill in your actual values

# SMTP Configuration for Email Sending
# These variables are used by the email service to send OTP codes via email

# SMTP Server Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Sender Email Address
SMTP_FROM=NexusBank <noreply@nexusbank.com>

# Encryption Configuration
# Used for encrypting sensitive data like account numbers
# Generate a strong random key for production (at least 32 characters)
ENCRYPTION_KEY=your-strong-encryption-key-change-in-production

# Notes:
# - For Gmail, you need to create an App Password (not your regular password)
#   Instructions: https://support.google.com/accounts/answer/185833
# - Port 587 uses STARTTLS, Port 465 uses SSL/TLS
# - For other email providers, update SMTP_HOST and PORT accordingly
# - In development, if SMTP is not configured, emails will be logged to console
# - ENCRYPTION_KEY should be a strong random string (use: openssl rand -base64 32)
